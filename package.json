{
  "name": "cloudflare-mailbox-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply mailbox-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply mailbox-db --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "postal-mime": "^2.7.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.110.0"
  }
}
